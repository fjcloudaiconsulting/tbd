# =============================================================================
# The Better Decision — Environment Configuration
#
# Copy to .env and fill in values: cp .env.example .env
# Full reference: see ENVIRONMENT.md at the repo root.
# =============================================================================

# --- Database (required) ---
# Connection string used by the FastAPI backend (async aiomysql driver).
# Must match the MYSQL_USER / MYSQL_PASSWORD / MYSQL_DATABASE values below
# since both the app and the mysql container init read this same .env file.
DATABASE_URL=mysql+aiomysql://pfv2:pfv2_secret@mysql:3306/pfv2

# Local MySQL container init — consumed by the `mysql` service in
# docker-compose.yml, not by the Python backend. Production MySQL runs
# on the pfv-data-01 droplet and does not read these.
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_DATABASE=pfv2
MYSQL_USER=pfv2
MYSQL_PASSWORD=pfv2_secret

# SQLAlchemy connection pool sizing per replica. Defaults are safe for a
# single-replica deployment. When scaling out (HPA), keep
# replicas * (DB_POOL_SIZE + DB_MAX_OVERFLOW) under the managed DB's
# max_connections cap. See ENVIRONMENT.md → K8S-3.
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# --- Auth (REQUIRED — the placeholder will be refused at startup) ---
# Generate a real secret (>= 32 chars) with ONE of:
#   openssl rand -hex 32
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Backend will refuse to boot if this is left at the placeholder or shorter
# than 32 chars (see backend/app/config.py field_validator).
JWT_SECRET_KEY=change-me-generate-a-real-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
# Session TTL (days): drives the refresh cookie Max-Age, the refresh JWT
# exp claim, the Redis primary-key TTL, AND the absolute-lifetime check.
# Per-org override is the OrgSetting(key="session_lifetime_days") row,
# settable from the Security settings page (1-365 days, validated).
# Range 1-365; out-of-range values refuse to boot.
# SESSION_LIFETIME_DAYS=30

# --- App ---
APP_NAME="The Better Decision"
# `development` enables lifespan auto-migrations, dev-mode email logger,
# and looser MFA fallback. `production` defers migrations to PRE_DEPLOY
# and requires Redis for MFA email-fallback codes.
APP_ENV=development
LOG_LEVEL=INFO
# Comma-separated allowlist for Access-Control-Allow-Origin. Browser
# enforces this; mismatch causes blocked XHRs with CORS errors.
BACKEND_CORS_ORIGINS=http://localhost

# --- Cookies ---
# Set to false for local development (HTTP), true for production (HTTPS).
# If `true` on HTTP, browsers drop the refresh / step-up cookies and login
# enters an infinite redirect loop.
COOKIE_SECURE=false

# --- CAPTCHA (registration bot gate) ---
# When CAPTCHA_REQUIRED=true the /api/v1/auth/register endpoint refuses
# registration unless the body carries a valid `captcha_token` confirmed by
# the provider's siteverify endpoint. Default OFF for local dev so the seed
# / smoke flow continues to work without a Cloudflare account. Production
# flips this on via .do/app.yaml. The /api/v1/auth/status endpoint exposes
# the same flag so the frontend renders the widget only when required.
#
# CAPTCHA_SECRET is the Cloudflare Turnstile siteverify secret (or matching
# secret for another provider). Cloudflare's always-pass test secret
# `1x0000000000000000000000000000000AA` returns success on any token and is
# safe to commit in dev configs.
CAPTCHA_REQUIRED=false
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET=1x0000000000000000000000000000000AA
CAPTCHA_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
CAPTCHA_VERIFY_TIMEOUT_S=5
# Optional pins. Empty disables the check. In production set HOSTNAME to
# the canonical app domain and ACTION to "register" so a token issued for
# a different page or origin is rejected even if the secret leaks.
CAPTCHA_EXPECTED_HOSTNAME=
CAPTCHA_EXPECTED_ACTION=

# --- Billing UI (customer-facing plan / trial / billing surface) ---
# When BILLING_UI_ENABLED=false (the pre-payment default), the trial
# banner, settings Billing tab, and /settings/billing plan grid are
# hidden from customers. Admin and operator views under /admin/* and
# /system/* are unaffected. Flip to true once the payment platform is
# wired. Exposed via /api/v1/auth/status so a backend flip becomes a
# real customer-facing change on the next page load.
BILLING_UI_ENABLED=false

# --- Reports v2 (flexible canvas + AST query engine) ---
# When FEATURE_REPORTS_V2=false (the pre-launch default), every route
# under /api/v1/reports returns 404 via a router-level dependency, and
# the frontend hides the nav item and routes (gated separately by
# NEXT_PUBLIC_FEATURE_REPORTS_V2). Both sides gate together; the
# backend 404 is the load-bearing one. Spec:
# specs/2026-05-22-reports-v2-flexible-canvas.md
FEATURE_REPORTS_V2=false
NEXT_PUBLIC_FEATURE_REPORTS_V2=false

# --- Plans (life-event scenario simulator) ---
# Env-var FLOOR for the Plans feature gate. When FEATURE_PLANS=false (the
# default), /api/v1/scenarios/* return 404 and the frontend hides the Plans
# nav item + /plans route. The gate resolves three levels — per-org override
# (OrgSetting feature.plans) -> global default (system_settings feature.plans)
# -> this env floor — so a superadmin can enable Plans globally or per-org at
# runtime without touching this value. No NEXT_PUBLIC_* twin: the frontend
# gates on the resolved flag from /api/v1/auth/status, not a build-time flag.
FEATURE_PLANS=false

# --- Frontend (NEXT_PUBLIC_*) ---
# Site key the Turnstile widget renders against. Build-time inlined into the
# Next.js bundle (changing it requires a frontend image rebuild). Test site
# key `1x00000000000000000000BB` always passes (matches the always-pass
# CAPTCHA_SECRET above) and is safe in dev. Empty value disables the widget
# render fallback even when CAPTCHA_REQUIRED=true on the backend.
NEXT_PUBLIC_CAPTCHA_PROVIDER=turnstile
NEXT_PUBLIC_CAPTCHA_SITE_KEY=1x00000000000000000000BB

# --- Redis ---
# Backing store for slowapi (cross-replica rate limit counters) and MFA
# email-fallback codes. Empty falls back to in-memory rate limiting and
# breaks MFA email fallback in production.
REDIS_URL=redis://redis:6379/0

# --- Email (Mailgun) ---
# Leave empty for development (emails logged to console).
# Set for production to send real emails via Mailgun.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
# Set to "eu" for EU Mailgun endpoint (api.eu.mailgun.net), leave empty for US.
# Mismatched region returns Mailgun 401.
MAILGUN_REGION=
EMAIL_FROM="The Better Decision <noreply@thebetterdecision.com>"
# Base URL embedded in password-reset, email-verify, MFA, invite, and
# Google SSO callback links. Set to your public origin in production.
APP_URL=http://localhost

# --- MFA ---
# Fernet key for encrypting users.mfa_secret_encrypted at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MFA_ENCRYPTION_KEY=

# --- AI credentials (BYO provider keys) ---
# Fernet key for encrypting per-org provider API keys stored in
# org_ai_credentials. MUST be a DIFFERENT value from MFA_ENCRYPTION_KEY —
# the lifespan startup guard refuses to boot when the two KEKs collide.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AI_CREDENTIAL_ENCRYPTION_KEY=
# Previous rotation slot. Set to the prior key during rotation so
# already-encrypted rows continue to decrypt. Clear once all rows have
# been re-encrypted with the current key.
AI_CREDENTIAL_ENCRYPTION_KEY_PREV=
# Master gate for the native (server-hosted) provider option. Stays
# off in PR1 — flipped on later with the native adapter + consent UI.
AI_NATIVE_ENABLED=false
# Pinned ToS version for the native-provider consent flow. POSTs to
# /api/v1/settings/ai-providers/consent must carry this exact
# consent_version. Bump to force every org to re-consent on the next
# admin-UI mount; existing rows are never auto-upgraded.
AI_NATIVE_CURRENT_CONSENT_VERSION=ai-tos-2026-05-22

# --- Google SSO ---
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# Set the authorized redirect URI to: {APP_URL}/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Runtime flags ---
# PFV_RUNTIME=app_platform tells get_client_ip in backend/app/rate_limit.py
# to honor the `do-connecting-ip` header (DigitalOcean App Platform writes
# the real client IP there). Set in production only; do not set in local
# dev. See ENVIRONMENT.md → Feature flags and runtime modes.
# PFV_RUNTIME=app_platform

# PFV_MIGRATE_OK_OFF_MAIN=1 lets `./pfv migrate` (and the FastAPI lifespan
# in dev) run alembic from a non-`main` checkout. Off-by-default to prevent
# feature branches from writing to the shared local MySQL volume.
# PFV_MIGRATE_OK_OFF_MAIN=1

# PFV_DEPDRIFT_SKIP=1 silences the host-vs-container package-lock.json SHA
# drift check that `./pfv start` runs. Use when you intentionally want to
# run with mismatched lockfiles.
# PFV_DEPDRIFT_SKIP=1

# --- Frontend ---
# When using nginx (default) or App Platform ingress, leave empty — API
# calls are same-origin via /api/. Only set this if running the frontend
# standalone without an ingress proxy.
NEXT_PUBLIC_API_URL=

# Set to "true" once GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET are configured
# AND the authorized redirect URI is registered with Google. The "Sign in
# with Google" button is hidden when this is not exactly "true" to avoid a
# broken-redirect UX. NEXT_PUBLIC_* env vars are baked into the static JS
# bundle at BUILD time, so a rebuild is required for changes to take effect.
NEXT_PUBLIC_GOOGLE_SSO_ENABLED=false

# Canonical site URL used for SEO metadata (canonical tags, sitemap, robots,
# Open Graph image URLs). Production should be the public origin visitors
# actually reach.
NEXT_PUBLIC_SITE_URL=https://app.thebetterdecision.com

# Stamped into in-app feedback widget payloads. Optional. Default `dev`.
# NEXT_PUBLIC_APP_VERSION=

# Google Analytics 4 measurement ID for the PUBLIC marketing/apex site only.
# GA is NOT loaded on the authenticated app (the component self-gates on
# NEXT_PUBLIC_BUILD_TARGET=apex). Empty disables GA entirely. Default is the
# production property.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-GRXDVTVBLV

# Google tag gateway first-party measurement path. The gtag.js loader is
# served from this same-origin path (CloudFront proxies it to the fps.goog
# origin) instead of googletagmanager.com, so no third-party request is made.
# Must match the CloudFront cache-behavior path pattern (currently /88x6/*).
NEXT_PUBLIC_GA_GATEWAY_PATH=/88x6/

# --- Billing ---
# DEFAULT_PLAN_SLUG=pro        # "pro" during beta, "free" when billing goes live
# TRIAL_DURATION_DAYS=14

# --- Seed helpers (used by ./pfv seed) ---
# Customize the seeded demo user. Defaults give the demo/demo1234 user
# documented in CONTRIBUTING.md.
# SEED_USERNAME=demo
# SEED_EMAIL=demo@example.com
# SEED_PASSWORD=demo1234
# SEED_FIRST_NAME=Demo
# SEED_LAST_NAME=User
# SEED_ORG="Demo Household"
